# Database Configuration
# For local development:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/clockroster"

# For Vercel Production (use Vercel Postgres or external service like Supabase):
# DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"

# NextAuth Configuration
# Generate a secure secret: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret-min-32-characters"

# For local development:
NEXTAUTH_URL="http://localhost:3000"

# For Vercel Production:
# NEXTAUTH_URL="https://your-app.vercel.app"

# NextAuth Secret (required for production)
NEXTAUTH_SECRET="replace-with-a-long-random-secret-min-32-characters"