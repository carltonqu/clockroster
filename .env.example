# ==========================================
# LOCAL DEVELOPMENT
# ==========================================

# Local PostgreSQL database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/clockroster"

# NextAuth Configuration for local development
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="replace-with-a-long-random-secret-min-32-characters"
NEXTAUTH_SECRET="replace-with-a-long-random-secret-min-32-characters"

# ==========================================
# VERCEL PRODUCTION (Vercel Postgres)
# ==========================================
# These are automatically set when you add Vercel Postgres to your project:
# - DATABASE_URL (pooled connection - for app usage)
# - DATABASE_URL_UNPOOLED (direct connection - for migrations)
# - POSTGRES_URL
# - POSTGRES_PRISMA_URL
# - POSTGRES_URL_NON_POOLING
# - POSTGRES_USER
# - POSTGRES_HOST
# - POSTGRES_PASSWORD
# - POSTGRES_DATABASE

# You only need to manually set these in Vercel Dashboard:
# NEXTAUTH_URL="https://your-app.vercel.app"
# NEXTAUTH_SECRET="your-generated-secret"
# AUTH_SECRET="your-generated-secret"